# Copy this file to .env and fill in real values, or export these
# directly in your shell / hosting provider's environment settings.
# The app reads all of these via os.environ in config.py -- nothing
# here is required to just run the app locally with demo data.

# --- Flask ---
SECRET_KEY=change-this-to-a-long-random-string-before-deploying
FLASK_DEBUG=1
ADMIN_PASSWORD=changeme

# --- Scraper ---
UPDATE_INTERVAL_MINUTES=30
PLAYWRIGHT_TIMEOUT_MS=20000

# --- Email notifications (leave blank to disable) ---
# Gmail: EMAIL_PASSWORD must be an App Password, not your login password.
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# --- SMS notifications via Twilio (leave blank to disable) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Weather (OpenWeather) -- leave blank to disable ---
OPENWEATHER_API_KEY=

# --- Geocoding (LocationIQ) -- leave blank to disable ---
LOCATIONIQ_API_KEY=

# --- Email via Resend (leave blank to use SMTP or disable) ---
# If set, takes priority over EMAIL_USER/EMAIL_PASSWORD above.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=onboarding@resend.dev

# --- Deployment ---
# Used to build unsubscribe links in notification emails.
SITE_BASE_URL=http://127.0.0.1:5000
